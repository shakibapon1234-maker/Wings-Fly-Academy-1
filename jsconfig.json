{
  "compilerOptions": {
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "allowJs": true,
    "maxNodeModuleJsDepth": 1
  },
  "include": [
    "js/**/*.js",
    "tests/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios"
  ]
}
